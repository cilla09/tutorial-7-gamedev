[sub_resource type="GDScript" id="GDScript_jvwwx"]
script/source = "extends CanvasLayer

@onready var item_count_label: Label = $BottomBar/ItemCountLabel
@onready var movement_label: Label = $BottomBar/MovementLabel

@onready var player = %Player

func _process(_delta):
	if player == null:
		return
	
	update_movement_state(player.is_sprinting, player.is_crouching)
	update_item_count(player.inventory.size(), player.MAX_INVENTORY_SLOTS)

func update_movement_state(is_sprinting: bool, is_crouching: bool):
	if is_crouching:
		movement_label.text = \"🧎 Crouching\"
		movement_label.modulate = Color(0.6, 0.9, 1.0)
	elif is_sprinting:
		movement_label.text = \"💨 Sprinting\"
		movement_label.modulate = Color(1.0, 0.85, 0.2)
	else:
		movement_label.text = \"\"

func update_item_count(count: int, max_slots: int):
	item_count_label.text = \"🎒 %d / %d\" % [count, max_slots]
"

